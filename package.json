{
    "name": "@odg/eslint-config",
    "version": "3.2.12",
    "description": "Linter for JavaScript And Typescript project",
    "type": "module",
    "main": "index.mjs",
    "types": "index.d.ts",
    "bin": {
        "odg-lint": "./lint.mjs"
    },
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "import": "./index.mjs"
        }
    },
    "author": "Dragons Gamers <https://www.linkedin.com/in/victor-alves-odgodinho>",
    "scripts": {
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "odg-lint": "node lint.mjs"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ODGodinho/ODG-Linter-Js.git"
    },
    "license": "MIT",
    "devDependencies": {
        "@odg/tsconfig": "^1.2.1",
        "@types/node": ">=24",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@babel/core": "^7.29.0",
        "@odg/eslint-plugin": "^1.0.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "any-eslint-parser": "^1.0.1",
        "eslint": "^9.39.4",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-antfu": "^3.2.2",
        "eslint-plugin-array-func": "^5.1.1",
        "eslint-plugin-better-max-params": "^1.0.0",
        "eslint-plugin-file-progress": "^3.0.2",
        "eslint-plugin-filenames": "^1.3.2",
        "eslint-plugin-html": "^8.1.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^62.8.1",
        "eslint-plugin-json-schema-validator": "^6.2.0",
        "eslint-plugin-jsonc": "3.1.2",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-no-constructor-bind": "^2.0.4",
        "eslint-plugin-php-markup": "^6.0.0",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-regex": "^1.10.0",
        "eslint-plugin-regexp": "^3.1.0",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.2",
        "eslint-plugin-sort-class-members": "^1.21.0",
        "eslint-plugin-toml": "^1.3.1",
        "eslint-plugin-unicorn": "^63.0.0",
        "eslint-plugin-yml": "^3.3.1",
        "espree": "^11.2.0",
        "globals": "^17.4.0",
        "jsonc-eslint-parser": "^3.1.0",
        "toml-eslint-parser": "^1.0.3",
        "ts-api-utils": "^2.5.0",
        "yaml-eslint-parser": "^2.0.0"
    },
    "peerDependencies": {
        "eslint": ">=9.39.2",
        "typescript": ">=5"
    },
    "peerDependenciesMeta": {
        "eslint": {
            "optional": true
        },
        "typescript": {
            "optional": true
        }
    },
    "bundledDependencies": [
        "eslint",
        "eslint-plugin-sonarjs",
        "globals",
        "ts-api-utils",
        "@odg/eslint-plugin",
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser"
    ],
    "files": [
        "./index.d.ts",
        "./index.mjs",
        "./lint.mjs",
        "./rules/"
    ],
    "bugs": {
        "url": "https://github.com/ODGodinho/ODG-Linter-Js/issues"
    },
    "homepage": "https://github.com/ODGodinho/ODG-Linter-Js#readme",
    "packageManager": "yarn@4.13.0"
}
